# ═══════════════════════════════════════════════════════
#  Tanla AI — Production environment variables
#  Bu faylni .env nomiga ko'chiring va qiymatlarni to'ldiring
# ═══════════════════════════════════════════════════════

# Django
SECRET_KEY=                        # python -c "import secrets; print(secrets.token_urlsafe(50))"
DEBUG=False                        # Prodaktsiyada DOIM False bo'lishi kerak
BACKEND_URL=https://your-domain.com

# Hosts (vergul bilan ajratilgan)
ALLOWED_HOSTS=your-domain.com,www.your-domain.com

# Database (bo'sh qoldirilsa SQLite ishlatiladi)
DATABASE_URL=                      # postgresql://user:pass@host:5432/dbname

# Telegram
TELEGRAM_BOT_TOKEN=                # @BotFather dan oling
ADMIN_TELEGRAM_IDS=                # Admin Telegram ID lari (vergul bilan)
TELEGRAM_WEBHOOK_SECRET=           # Ixtiyoriy: webhook xavfsizligi uchun

# OpenAI
OPENAI_API_KEY=                    # https://platform.openai.com/api-keys

# Deploy (VPS da systemctl restart uchun)
ALLOW_ADMIN_DEPLOY_ACTIONS=False
ADMIN_RESTART_COMMAND=sudo systemctl restart tanla-ai.service
ADMIN_STATUS_COMMAND=sudo systemctl status tanla-ai.service --no-pager

# Gunicorn
GUNICORN_WORKERS=                  # Bo'sh: 2*CPU+1 avtomatik hisoblanadi
GUNICORN_LOG_LEVEL=info
